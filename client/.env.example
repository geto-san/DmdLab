# Copy this file to .env for local development (never commit .env).
# Vite only auto-loads files literally named .env / .env.local / .env.[mode] —
# the previous "env.env" file in this repo was never actually picked up.

# Base URL of the DmdLab API server
VITE_API_BASE=http://localhost:8500

# Must match server CLOUDINARY_CLOUD_NAME — used to build thumbnail URLs
# in the admin UI directly from Cloudinary, without another API round trip.
VITE_CLOUDINARY_CLOUD_NAME=

APP_NAME=DmdLab
